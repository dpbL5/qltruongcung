# =============================================================================
# Victoria Archery Club — POS System
# Template biến môi trường. Copy sang .env và điền giá trị thực.
# =============================================================================

# ── PostgreSQL (bắt buộc) ────────────────────────────────────────────────────
# Local dev: Docker Compose (docker compose up -d)
DATABASE_URL="postgresql://posadmin:change-me-in-production@localhost:5432/qltruongcung?schema=public"

# Docker Compose credentials (phải khớp với user/password trong DATABASE_URL)
POSTGRES_USER="posadmin"
POSTGRES_PASSWORD="change-me-in-production"
POSTGRES_DB="qltruongcung"

# ── Supabase / Production ────────────────────────────────────────────────────
# Transaction-mode pooler (port 6543) — dùng cho application queries:
#   - PgBouncer transaction mode multiplexing hiệu quả cho serverless
#   - Code đã hỗ trợ: tắt prepared statement cache tự động khi detect port 6543
#     hoặc `?pgbouncer=true` trong connection string
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=app"
#
# Direct connection (session pooler port 5432) — dùng cho migrations / db push:
#   - prisma db push và migration cần connection ổn định, bypass transaction pooler
#   - Nếu không set DIRECT_URL, Prisma CLI fallback về DATABASE_URL
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?schema=app"

# ── Auth (bắt buộc) ─────────────────────────────────────────────────────────
# Secret ký JWT HS256. Phải ≥ 32 ký tự.
# Tạo mới: openssl rand -hex 32
SESSION_SECRET="replace-me-with-a-random-32-char-hex-string"

# ── Runtime ─────────────────────────────────────────────────────────────────
# Next.js tự động set theo lệnh (dev/build/start). Chỉ set thủ công nếu cần.
# NODE_ENV="development"

# ── Admin seed — npm run seed:admin (tuỳ chọn, có default) ──────────────────
# ADMIN_USERNAME="admin"
# ADMIN_PASSWORD="change-me-before-deploy"
# ADMIN_FULL_NAME="Quản trị viên"

# ── API seed — POST /api/seed (tuỳ chọn, tự sinh nếu không set) ────────────
# SEED_ADMIN_PASSWORD="admin123"
# SEED_STAFF_PASSWORD="staff123"
