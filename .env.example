# PostgreSQL connection string for Prisma + pg adapter.
# Local dev: your local Postgres instance.
# Production: Supabase session pooler URI (port 5432), NOT the direct connection (port 6543).
DATABASE_URL="postgresql://user:password@localhost:5432/qltruongcung"

# Secret for signing session JWTs (HS256 via jose).
# Must be at least 32 characters. Generate with: openssl rand -hex 32
# The value below is a placeholder — never commit a real secret.
SESSION_SECRET="replace-me-with-a-random-32-char-hex-string"

# Next.js runtime — set by Vercel automatically in production.
# NODE_ENV="development"
