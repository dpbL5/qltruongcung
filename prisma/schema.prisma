// Prisma Schema: victoriapos

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enums

enum UserRole {
  ADMIN
  STAFF
}

enum CustomerType {
  WALK_IN
  MEMBER
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum DayType {
  WEEKDAY
  WEEKEND
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum MembershipStatus {
  ACTIVE
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  PAID
  CANCELLED
}

enum InvoiceItemType {
  PLAY_TIME
  MEMBERSHIP_FEE
  PRODUCT
  SERVICE
  DISCOUNT
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum StockMovementType {
  RESTOCK
  SALE
  ADJUSTMENT
  VOID
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum ShiftParticipantRole {
  LEAD
  STAFF
}

// Models

model User {
  id           String   @id @default(uuid())
  username     String   @unique @db.VarChar(50)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  fullName     String   @map("full_name") @db.VarChar(100)
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions           Session[]
  payments           Payment[]
  shifts             Shift[]
  shiftParticipants  ShiftParticipant[]
  invoices           Invoice[]
  stockMovements     StockMovement[]
  membershipPayments MembershipPayment[]
  activityLogs       ActivityLog[]

  @@map("users")
}

model Customer {
  id               String       @id @default(uuid())
  fullName         String       @map("full_name") @db.VarChar(100)
  phone            String?      @db.VarChar(20)
  type             CustomerType @default(WALK_IN)
  totalHoursPlayed Decimal      @default(0) @map("total_hours_played") @db.Decimal(10, 2)
  totalSpent       Decimal      @default(0) @map("total_spent") @db.Decimal(12, 0)
  notes            String?      @db.Text
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  sessions           Session[]
  memberships        Membership[]
  membershipPayments MembershipPayment[]
  invoices           Invoice[]

  @@index([type])
  @@map("customers")
}

model Session {
  id             String        @id @default(uuid())
  customerId     String        @map("customer_id")
  customer       Customer      @relation(fields: [customerId], references: [id])
  staffId        String        @map("staff_id")
  staff          User          @relation(fields: [staffId], references: [id])
  shiftId        String?       @map("shift_id")
  shift          Shift?        @relation(fields: [shiftId], references: [id])
  membershipId   String?       @map("membership_id")
  membership     Membership?   @relation(fields: [membershipId], references: [id])
  startTime      DateTime      @map("start_time")
  endTime        DateTime?     @map("end_time")
  status         SessionStatus @default(ACTIVE)
  totalHours     Decimal?      @map("total_hours") @db.Decimal(5, 2)
  hourlyRate     Decimal       @map("hourly_rate") @db.Decimal(10, 0)
  subtotal       Decimal?      @db.Decimal(12, 0)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 0)
  totalAmount    Decimal?      @map("total_amount") @db.Decimal(12, 0)
  notes          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  payment  Payment?
  invoices Invoice[]

  @@index([customerId, status])
  @@index([shiftId])
  @@index([membershipId])
  @@map("sessions")
}

model PricingRule {
  id            String    @id @default(uuid())
  name          String    @db.VarChar(100)
  daysOfWeek    Int[]     @default([]) @map("days_of_week")
  hourFrom      Int       @map("hour_from")
  hourTo        Int?      @map("hour_to")
  ratePerHour   Decimal   @map("rate_per_hour") @db.Decimal(12, 2)
  dayType       DayType   @default(WEEKDAY) @map("day_type")
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([dayType, hourFrom, hourTo])
  @@map("pricing_rules")
}

model MembershipPlan {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  durationMonths Int      @default(1) @map("duration_months")
  price          Decimal  @db.Decimal(12, 0)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  memberships        Membership[]
  membershipPayments MembershipPayment[]

  @@map("membership_plans")
}

model Membership {
  id         String           @id @default(uuid())
  customerId String           @map("customer_id")
  customer   Customer         @relation(fields: [customerId], references: [id])
  planId     String           @map("plan_id")
  plan       MembershipPlan   @relation(fields: [planId], references: [id])
  startsAt   DateTime         @map("starts_at")
  expiresAt  DateTime         @map("expires_at")
  status     MembershipStatus @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  sessions           Session[]
  membershipPayments MembershipPayment[]

  @@index([customerId, startsAt, expiresAt])
  @@index([status])
  @@map("memberships")
}

model MembershipPayment {
  id            String         @id @default(uuid())
  customerId    String         @map("customer_id")
  customer      Customer       @relation(fields: [customerId], references: [id])
  membershipId  String         @map("membership_id")
  membership    Membership     @relation(fields: [membershipId], references: [id])
  planId        String         @map("plan_id")
  plan          MembershipPlan @relation(fields: [planId], references: [id])
  invoiceId     String?        @map("invoice_id")
  invoice       Invoice?       @relation(fields: [invoiceId], references: [id])
  shiftId       String?        @map("shift_id")
  shift         Shift?         @relation(fields: [shiftId], references: [id])
  staffId       String         @map("staff_id")
  staff         User           @relation(fields: [staffId], references: [id])
  amount        Decimal        @db.Decimal(12, 0)
  paymentMethod PaymentMethod  @map("payment_method")
  paidAt        DateTime       @default(now()) @map("paid_at")
  notes         String?        @db.Text
  createdAt     DateTime       @default(now()) @map("created_at")

  @@index([customerId, paidAt])
  @@index([invoiceId])
  @@index([shiftId])
  @@map("membership_payments")
}

model Shift {
  id             String      @id @default(uuid())
  staffId        String      @map("staff_id")
  staff          User        @relation(fields: [staffId], references: [id])
  openSlot       String?     @unique @map("open_slot") @db.VarChar(30)
  openedAt       DateTime    @default(now()) @map("opened_at")
  closedAt       DateTime?   @map("closed_at")
  openingCash    Decimal     @default(0) @map("opening_cash") @db.Decimal(12, 0)
  closingCash    Decimal?    @map("closing_cash") @db.Decimal(12, 0)
  expectedCash   Decimal?    @map("expected_cash") @db.Decimal(12, 0)
  cashDifference Decimal?    @map("cash_difference") @db.Decimal(12, 0)
  status         ShiftStatus @default(OPEN)
  notes          String?     @db.Text
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  sessions           Session[]
  participants       ShiftParticipant[]
  invoices           Invoice[]
  payments           Payment[]
  membershipPayments MembershipPayment[]
  stockMovements     StockMovement[]

  @@index([staffId, status])
  @@index([openedAt])
  @@map("shifts")
}

model ShiftParticipant {
  id        String               @id @default(uuid())
  shiftId   String               @map("shift_id")
  shift     Shift                @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  staffId   String               @map("staff_id")
  staff     User                 @relation(fields: [staffId], references: [id])
  role      ShiftParticipantRole @default(STAFF)
  joinedAt  DateTime             @default(now()) @map("joined_at")
  leftAt    DateTime?            @map("left_at")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@unique([shiftId, staffId])
  @@index([staffId, leftAt])
  @@index([shiftId, leftAt])
  @@map("shift_participants")
}

model Invoice {
  id            String        @id @default(uuid())
  invoiceNo     String        @unique @map("invoice_no") @db.VarChar(40)
  customerId    String?       @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id])
  sessionId     String?       @map("session_id")
  session       Session?      @relation(fields: [sessionId], references: [id])
  shiftId       String?       @map("shift_id")
  shift         Shift?        @relation(fields: [shiftId], references: [id])
  staffId       String        @map("staff_id")
  staff         User          @relation(fields: [staffId], references: [id])
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @default(0) @db.Decimal(12, 0)
  discountTotal Decimal       @default(0) @map("discount_total") @db.Decimal(12, 0)
  grandTotal    Decimal       @default(0) @map("grand_total") @db.Decimal(12, 0)
  paidAt        DateTime?     @map("paid_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  items              InvoiceItem[]
  payments           Payment[]
  membershipPayments MembershipPayment[]

  @@index([customerId])
  @@index([sessionId])
  @@index([shiftId])
  @@index([paidAt])
  @@map("invoices")
}

model InvoiceItem {
  id             String          @id @default(uuid())
  invoiceId      String          @map("invoice_id")
  invoice        Invoice         @relation(fields: [invoiceId], references: [id])
  productId      String?         @map("product_id")
  product        Product?        @relation(fields: [productId], references: [id])
  type           InvoiceItemType
  description    String          @db.VarChar(200)
  quantity       Decimal         @default(1) @db.Decimal(10, 2)
  unitPrice      Decimal         @default(0) @map("unit_price") @db.Decimal(12, 0)
  subtotal       Decimal         @default(0) @db.Decimal(12, 0)
  discountAmount Decimal         @default(0) @map("discount_amount") @db.Decimal(12, 0)
  total          Decimal         @default(0) @db.Decimal(12, 0)
  metadata       Json?           @db.JsonB
  createdAt      DateTime        @default(now()) @map("created_at")

  stockMovements StockMovement[]

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id            String        @id @default(uuid())
  sessionId     String?       @unique @map("session_id")
  session       Session?      @relation(fields: [sessionId], references: [id])
  invoiceId     String?       @map("invoice_id")
  invoice       Invoice?      @relation(fields: [invoiceId], references: [id])
  shiftId       String?       @map("shift_id")
  shift         Shift?        @relation(fields: [shiftId], references: [id])
  staffId       String        @map("staff_id")
  staff         User          @relation(fields: [staffId], references: [id])
  totalHours    Decimal       @map("total_hours") @db.Decimal(5, 2)
  subtotal      Decimal       @db.Decimal(12, 0)
  discountTotal Decimal       @default(0) @map("discount_total") @db.Decimal(12, 0)
  grandTotal    Decimal       @map("grand_total") @db.Decimal(12, 0)
  paymentMethod PaymentMethod @map("payment_method")
  paidAt        DateTime      @default(now()) @map("paid_at")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([invoiceId])
  @@index([shiftId])
  @@map("payments")
}

model Product {
  id            String      @id @default(uuid())
  name          String      @db.VarChar(120)
  sku           String?     @unique @db.VarChar(50)
  type          ProductType @default(PRODUCT)
  price         Decimal     @db.Decimal(12, 0)
  costPrice     Decimal?    @map("cost_price") @db.Decimal(12, 0)
  stockQuantity Int         @default(0) @map("stock_quantity")
  minStockLevel Int         @default(0) @map("min_stock_level")
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  invoiceItems   InvoiceItem[]
  stockMovements StockMovement[]

  @@index([isActive])
  @@map("products")
}

model StockMovement {
  id            String            @id @default(uuid())
  productId     String            @map("product_id")
  product       Product           @relation(fields: [productId], references: [id])
  invoiceItemId String?           @map("invoice_item_id")
  invoiceItem   InvoiceItem?      @relation(fields: [invoiceItemId], references: [id])
  shiftId       String?           @map("shift_id")
  shift         Shift?            @relation(fields: [shiftId], references: [id])
  staffId       String?           @map("staff_id")
  staff         User?             @relation(fields: [staffId], references: [id])
  type          StockMovementType
  quantity      Int
  unitCost      Decimal?          @map("unit_cost") @db.Decimal(12, 0)
  reason        String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")

  @@index([productId, createdAt])
  @@index([shiftId])
  @@map("stock_movements")
}

model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String   @map("entity_id") @db.Uuid
  details    Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("activity_logs")
}
